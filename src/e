#!/usr/bin/env node
// Thin shim to the compiled entry point. Kept here so existing installer
// wrappers that point at src/e continue to work.
const fs = require('node:fs');
const path = require('node:path');
const cp = require('node:child_process');

const root = path.resolve(__dirname, '..');
const distEntry = path.resolve(root, 'dist', 'e.js');

if (!fs.existsSync(distEntry)) {
  // First run after upgrading from a pre-TypeScript build-tools: the old
  // auto-updater only ran `yarn --immutable` and did not know to build
  // dist/. Build it now so `e` is usable immediately after the upgrade.
  console.log('Building build-tools (first run after TypeScript migration)...');
  const yarnPath = path.resolve(root, '.yarn', 'releases', 'yarn-4.10.3.cjs');
  const result = cp.spawnSync(process.execPath, [yarnPath, 'build'], {
    cwd: root,
    stdio: 'inherit',
  });
  if (result.status !== 0) {
    console.error('Failed to build build-tools. Please run `yarn build` manually in', root);
    process.exit(result.status || 1);
  }
}

require(distEntry);
